<Window x:Class="DeployManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DeployManager.ViewModels"
        xmlns:views="clr-namespace:DeployManager.Views"
        mc:Ignorable="d"
        Title="DataForgeStudio 系统管理" Height="680" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F5"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- 主内容区域 -->
        <Grid Grid.Row="0" Margin="15">
            <!-- 选项卡导航 -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 选项卡按钮 -->
                    <Border Grid.Row="0" Background="#FFF8F8F8" BorderBrush="#FFE0E0E0"
                           BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="服务管理" Command="{Binding SelectServiceTabCommand}"
                                   Padding="25,12" FontSize="14" Cursor="Hand"
                                   Background="Transparent" BorderThickness="0,0,0,2">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="#FF666666"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsServiceTabSelected}" Value="True">
                                                <Setter Property="Foreground" Value="#FF1976D2"/>
                                                <Setter Property="BorderBrush" Value="#FF1976D2"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFF0F0F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="数据库配置" Command="{Binding SelectDatabaseTabCommand}"
                                   Padding="25,12" FontSize="14" Cursor="Hand"
                                   Background="Transparent" BorderThickness="0,0,0,2">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="#FF666666"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDatabaseTabSelected}" Value="True">
                                                <Setter Property="Foreground" Value="#FF1976D2"/>
                                                <Setter Property="BorderBrush" Value="#FF1976D2"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFF0F0F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="端口配置" Command="{Binding SelectPortTabCommand}"
                                   Padding="25,12" FontSize="14" Cursor="Hand"
                                   Background="Transparent" BorderThickness="0,0,0,2">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="#FF666666"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPortTabSelected}" Value="True">
                                                <Setter Property="Foreground" Value="#FF1976D2"/>
                                                <Setter Property="BorderBrush" Value="#FF1976D2"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFF0F0F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="前端模式" Command="{Binding SelectFrontendTabCommand}"
                                   Padding="25,12" FontSize="14" Cursor="Hand"
                                   Background="Transparent" BorderThickness="0,0,0,2">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="#FF666666"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFrontendTabSelected}" Value="True">
                                                <Setter Property="Foreground" Value="#FF1976D2"/>
                                                <Setter Property="BorderBrush" Value="#FF1976D2"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFF0F0F0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 内容区域 -->
                    <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="20">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vm:ServiceControlViewModel}">
                                <views:ServiceControlView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:DatabaseConfigViewModel}">
                                <views:DatabaseConfigView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:PortConfigViewModel}">
                                <views:PortConfigView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:FrontendModeViewModel}">
                                <views:FrontendModeView/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="1" Background="#FF37474F" Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 运行状态 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,30,0">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{Binding StatusColor}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ServiceControl.IsRunning}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="1.0" To="0.5" Duration="0:0:1"
                                                                    AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 端口信息 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                              Foreground="#AAFFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding PortText}" Foreground="#CCFFFFFF" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 模式信息 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                              Foreground="#AAFFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ModeText}" Foreground="#CCFFFFFF" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
