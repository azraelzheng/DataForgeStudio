<UserControl x:Class="DeployManager.Views.PortConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 端口配置 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,15">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="端口配置" FontSize="16" FontWeight="Bold"
                          Foreground="#FF333333" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 后端端口 -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="后端 API 端口" FontSize="13" Foreground="#FF666666" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding BackendPort, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource InputTextBoxStyle}"/>
                        <TextBlock Text="后端服务监听端口 (默认: 5000)" FontSize="11"
                                  Foreground="#FF999999" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- 前端端口 -->
                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock Text="前端 Web 端口" FontSize="13" Foreground="#FF666666" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FrontendPort, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource InputTextBoxStyle}"/>
                        <TextBlock Text="前端服务监听端口 (默认: 80)" FontSize="11"
                                  Foreground="#FF999999" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 提示信息 -->
        <Border Grid.Row="1" Background="#FFFFF8E1" BorderBrush="#FFFFB300"
               BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                          Foreground="#FFFF8F00" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="修改端口配置后需要重启服务才能生效" FontSize="13"
                          Foreground="#FFF57C00" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 保存结果 -->
        <Border Grid.Row="2" Margin="0,0,0,15" CornerRadius="8" Padding="15"
               Visibility="{Binding SaveResult, Converter={StaticResource BoolToVisibility}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SaveSuccess}" Value="True">
                            <Setter Property="Background" Value="#FFE8F5E9"/>
                            <Setter Property="BorderBrush" Value="#FF4CAF50"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SaveSuccess}" Value="False">
                            <Setter Property="Background" Value="#FFFFEBEE"/>
                            <Setter Property="BorderBrush" Value="#FFF44336"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="0,0,10,0"
                          VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE73E;"/>
                            <Setter Property="Foreground" Value="#FF4CAF50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SaveSuccess}" Value="False">
                                    <Setter Property="Text" Value="&#xE711;"/>
                                    <Setter Property="Foreground" Value="#FFF44336"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding SaveResult}" FontSize="14" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF2E7D32"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SaveSuccess}" Value="False">
                                    <Setter Property="Foreground" Value="#FFC62828"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 保存按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding SaveCommand}"
                   Width="100" Height="40">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                              Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="保存" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
