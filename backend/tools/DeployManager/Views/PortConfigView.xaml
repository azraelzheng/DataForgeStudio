<UserControl x:Class="DeployManager.Views.PortConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 端口配置 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <TextBlock Grid.Row="0" Text="端口配置" FontSize="14" FontWeight="Bold"
                          Foreground="#FF333333" Margin="0,0,0,12"/>

                <!-- 端口输入 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 后端端口 -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="后端 API 端口" FontSize="12" Foreground="#FF666666" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding BackendPort, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource InputTextBoxStyle}" Height="30"/>
                        <TextBlock Text="默认: 5000" FontSize="11" Foreground="#FF999999" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- 前端端口 -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="前端 Web 端口" FontSize="12" Foreground="#FF666666" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FrontendPort, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource InputTextBoxStyle}" Height="30"/>
                        <TextBlock Text="默认: 80" FontSize="11" Foreground="#FF999999" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- 测试结果和操作按钮 -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 测试结果 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                           Visibility="{Binding HasTestResult, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="0,0,8,0"
                              VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE73E;"/>
                                <Setter Property="Foreground" Value="#FF4CAF50"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TestSuccess}" Value="False">
                                        <Setter Property="Text" Value="&#xE711;"/>
                                        <Setter Property="Foreground" Value="#FFF44336"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding TestResult}" FontSize="13" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF2E7D32"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TestSuccess}" Value="False">
                                        <Setter Property="Foreground" Value="#FFC62828"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding TestPortsCommand}"
                           Width="100" Height="32" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                      Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="检测端口" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DefaultButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Command="{Binding SaveCommand}" Width="80" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                      Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="保存" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 提示信息 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                      Foreground="#FF999999" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBlock Text="提示：请先检测端口可用后再保存，修改端口后需要重启服务才能生效"
                      FontSize="11" Foreground="#FF999999"/>
        </StackPanel>
    </Grid>
</UserControl>
