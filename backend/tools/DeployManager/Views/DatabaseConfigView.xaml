<UserControl x:Class="DeployManager.Views.DatabaseConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 连接信息 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,15">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="数据库连接信息" FontSize="16" FontWeight="Bold"
                          Foreground="#FF333333" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 服务器地址 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,15">
                        <TextBlock Text="服务器地址" FontSize="13" Foreground="#FF666666" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource InputTextBoxStyle}"/>
                    </StackPanel>

                    <!-- 端口号 -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,15">
                        <TextBlock Text="端口号" FontSize="13" Foreground="#FF666666" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource InputTextBoxStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 认证方式 -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,15">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="认证方式" FontSize="16" FontWeight="Bold"
                          Foreground="#FF333333" Margin="0,0,0,20"/>

                <!-- 认证方式选择 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <RadioButton Content="Windows 身份验证" IsChecked="{Binding UseWindowsAuth}"
                                FontSize="14" Margin="0,0,30,0" GroupName="AuthType"
                                VerticalContentAlignment="Center"/>
                    <RadioButton Content="SQL Server 身份验证" IsChecked="{Binding IsSqlAuth, Mode=OneWay}"
                                FontSize="14" GroupName="AuthType"
                                VerticalContentAlignment="Center"
                                Click="OnSqlAuthRadioClick"/>
                </StackPanel>

                <!-- SQL 认证凭据 -->
                <Grid Visibility="{Binding IsSqlAuth, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 用户名 -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="用户名" FontSize="13" Foreground="#FF666666" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource InputTextBoxStyle}"/>
                    </StackPanel>

                    <!-- 密码 -->
                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock Text="密码" FontSize="13" Foreground="#FF666666" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="PasswordBox"
                                    Style="{StaticResource PasswordBoxStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 测试结果 -->
        <Border Grid.Row="2" Margin="0,0,0,15" CornerRadius="8" Padding="15"
               Visibility="{Binding HasTestResult, Converter={StaticResource BoolToVisibility}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TestSuccess}" Value="True">
                            <Setter Property="Background" Value="#FFE8F5E9"/>
                            <Setter Property="BorderBrush" Value="#FF4CAF50"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding TestSuccess}" Value="False">
                            <Setter Property="Background" Value="#FFFFEBEE"/>
                            <Setter Property="BorderBrush" Value="#FFF44336"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="0,0,10,0"
                          VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE73E;"/>
                            <Setter Property="Foreground" Value="#FF4CAF50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TestSuccess}" Value="False">
                                    <Setter Property="Text" Value="&#xE711;"/>
                                    <Setter Property="Foreground" Value="#FFF44336"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding TestResult}" FontSize="14" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF2E7D32"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TestSuccess}" Value="False">
                                    <Setter Property="Foreground" Value="#FFC62828"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- 测试连接按钮 -->
            <Button Command="{Binding TestConnectionCommand}"
                   Width="120" Height="40" Margin="0,0,15,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                              Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="测试连接" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource DefaultButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- 保存按钮 -->
            <Button Command="{Binding SaveCommand}"
                   Width="100" Height="40">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                              Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="保存" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
