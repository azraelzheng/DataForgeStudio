<UserControl x:Class="DeployManager.Views.FrontendModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 当前模式 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,15">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="前端服务模式" FontSize="16" FontWeight="Bold"
                          Foreground="#FF333333" Margin="0,0,0,20"/>

                <!-- 模式选择卡片 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- IIS 模式卡片 -->
                    <Border Grid.Column="0" CornerRadius="8" Padding="20" Cursor="Hand"
                           BorderThickness="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIisMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF1976D2"/>
                                        <Setter Property="Background" Value="#FFE3F2FD"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                         Command="{Binding SwitchModeCommand}"
                                         CommandParameter="iis"/>
                        </Border.InputBindings>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- IIS 图标 -->
                            <Border Grid.Column="0" CornerRadius="8"
                                   Padding="12" Margin="0,0,15,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFE3F2FD"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsIisMode}" Value="True">
                                                <Setter Property="Background" Value="#FF1976D2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="IIS" FontSize="18" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF1976D2"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIisMode}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="IIS 模式" FontSize="16" FontWeight="Medium"
                                          Foreground="#FF333333"/>
                                <TextBlock Text="使用 Windows IIS 托管前端" FontSize="12"
                                          Foreground="#FF666666" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Nginx 模式卡片 -->
                    <Border Grid.Column="2" CornerRadius="8" Padding="20" Cursor="Hand"
                           BorderThickness="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNginxMode}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF4CAF50"/>
                                        <Setter Property="Background" Value="#FFE8F5E9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                         Command="{Binding SwitchModeCommand}"
                                         CommandParameter="nginx"/>
                        </Border.InputBindings>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Nginx 图标 -->
                            <Border Grid.Column="0" CornerRadius="8"
                                   Padding="12" Margin="0,0,15,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFE8F5E9"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNginxMode}" Value="True">
                                                <Setter Property="Background" Value="#FF4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="18">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF4CAF50"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsNginxMode}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Nginx 模式" FontSize="16" FontWeight="Medium"
                                          Foreground="#FF333333"/>
                                <TextBlock Text="使用 Nginx 反向代理前端" FontSize="12"
                                          Foreground="#FF666666" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 安装状态 -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,15">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="安装状态" FontSize="16" FontWeight="Bold"
                          Foreground="#FF333333" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- IIS 状态 -->
                    <Border Grid.Column="0" Margin="0,0,15,0" Padding="15" CornerRadius="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FFFFEBEE"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IisInstalled}" Value="True">
                                        <Setter Property="Background" Value="#FFE8F5E9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="0,0,10,0"
                                      VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE711;"/>
                                        <Setter Property="Foreground" Value="#FFF44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IisInstalled}" Value="True">
                                                <Setter Property="Text" Value="&#xE73E;"/>
                                                <Setter Property="Foreground" Value="#FF4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel>
                                <TextBlock Text="IIS" FontSize="14" FontWeight="Medium" Foreground="#FF333333"/>
                                <TextBlock FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="未安装"/>
                                            <Setter Property="Foreground" Value="#FFF44336"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IisInstalled}" Value="True">
                                                    <Setter Property="Text" Value="已安装"/>
                                                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Nginx 状态 -->
                    <Border Grid.Column="1" Margin="15,0,0,0" Padding="15" CornerRadius="8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FFFFEBEE"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NginxInstalled}" Value="True">
                                        <Setter Property="Background" Value="#FFE8F5E9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="0,0,10,0"
                                      VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE711;"/>
                                        <Setter Property="Foreground" Value="#FFF44336"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NginxInstalled}" Value="True">
                                                <Setter Property="Text" Value="&#xE73E;"/>
                                                <Setter Property="Foreground" Value="#FF4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel>
                                <TextBlock Text="Nginx" FontSize="14" FontWeight="Medium" Foreground="#FF333333"/>
                                <TextBlock FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="未安装"/>
                                            <Setter Property="Foreground" Value="#FFF44336"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NginxInstalled}" Value="True">
                                                    <Setter Property="Text" Value="已安装"/>
                                                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 操作结果 -->
        <Border Grid.Row="2" Margin="0,0,0,15" CornerRadius="8" Padding="15"
               Visibility="{Binding OperationResult, Converter={StaticResource BoolToVisibility}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="#FFE0E0E0"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding OperationSuccess}" Value="True">
                            <Setter Property="Background" Value="#FFE8F5E9"/>
                            <Setter Property="BorderBrush" Value="#FF4CAF50"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding OperationSuccess}" Value="False">
                            <Setter Property="Background" Value="#FFFFEBEE"/>
                            <Setter Property="BorderBrush" Value="#FFF44336"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Margin="0,0,10,0"
                          VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE73E;"/>
                            <Setter Property="Foreground" Value="#FF4CAF50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OperationSuccess}" Value="False">
                                    <Setter Property="Text" Value="&#xE711;"/>
                                    <Setter Property="Foreground" Value="#FFF44336"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding OperationResult}" FontSize="14" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF2E7D32"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OperationSuccess}" Value="False">
                                    <Setter Property="Foreground" Value="#FFC62828"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 提示信息 -->
        <Border Grid.Row="3" Background="#FFE3F2FD" BorderBrush="#FF1976D2"
               BorderThickness="1" CornerRadius="8" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                          Foreground="#FF1976D2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="切换前端模式会自动停止当前服务并启动新模式服务" FontSize="13"
                          Foreground="#FF1976D2" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
