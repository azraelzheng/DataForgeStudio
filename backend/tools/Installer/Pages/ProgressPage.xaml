<UserControl x:Class="Installer.Pages.ProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40">
        <StackPanel>
            <TextBlock Text="正在安装" Style="{StaticResource PageTitle}"/>
            <TextBlock Style="{StaticResource PageSubtitle}">
                请稍候，安装程序正在复制文件并配置系统...
            </TextBlock>

            <StackPanel Margin="0,20,0,0">
                <Grid>
                    <TextBlock Text="{Binding CurrentStep}" FontWeight="Medium"/>
                    <TextBlock Text="{Binding InstallProgress, StringFormat={}{0}%}" HorizontalAlignment="Right" Foreground="#666"/>
                </Grid>
                <ProgressBar Height="8" Margin="0,10,0,0" Value="{Binding InstallProgress}" Maximum="100" Foreground="#0078D4" Background="#E0E0E0"/>
            </StackPanel>

            <Border Background="#F8F8F8" Margin="0,20,0,0" CornerRadius="4" Height="200">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl ItemsSource="{Binding InstallLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas"
                                           TextWrapping="Wrap" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock Text="{Binding InstallError}" Foreground="#D13438" TextWrapping="Wrap" Margin="0,10,0,0"
                       Visibility="{Binding InstallError, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
