<UserControl x:Class="Installer.Pages.PortConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40">
        <StackPanel>
            <TextBlock Text="端口配置" Style="{StaticResource PageTitle}"/>
            <TextBlock Style="{StaticResource PageSubtitle}">
                配置前端访问端口和后端 API 端口。前端通过 Nginx 提供静态文件服务和反向代理。
            </TextBlock>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="前端端口:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Config.Frontend.Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="(用户访问端口，默认 80)" VerticalAlignment="Center" Foreground="#666" Margin="10,0,0,0"/>

                <Label Grid.Row="1" Grid.Column="0" Content="后端 API 端口:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Config.Backend.Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="(内部通信端口，默认 5000)" VerticalAlignment="Center" Foreground="#666" Margin="10,0,0,0"/>
            </Grid>

            <Border Background="#E3F2FD" Padding="15" CornerRadius="4" Margin="0,30,0,0">
                <StackPanel>
                    <TextBlock Text="工作原理：" FontWeight="Medium" Foreground="#1976D2" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#666">
                        <Run Text="1. 用户通过浏览器访问前端端口（如 http://localhost）"/>
                        <LineBreak/>
                        <Run Text="2. Nginx 提供前端静态文件"/>
                        <LineBreak/>
                        <Run Text="3. API 请求被 Nginx 代理到后端 API 端口"/>
                        <LineBreak/>
                        <Run Text="4. 后端服务处理后端业务逻辑"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
