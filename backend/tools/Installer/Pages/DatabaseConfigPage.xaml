<UserControl x:Class="Installer.Pages.DatabaseConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40">
        <StackPanel>
            <TextBlock Text="数据库配置" Style="{StaticResource PageTitle}"/>
            <TextBlock Style="{StaticResource PageSubtitle}">
                配置 SQL Server 数据库连接。数据库将在首次启动时自动创建。
            </TextBlock>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="服务器地址:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Config.Database.Server, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

                <Label Grid.Row="1" Grid.Column="0" Content="端口:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Config.Database.Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

                <Label Grid.Row="2" Grid.Column="0" Content="数据库名:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Config.Database.Database, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Background="#F0F0F0" Margin="0,5"/>

                <Label Grid.Row="3" Grid.Column="0" Content="认证方式:" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,10">
                    <RadioButton Content="Windows 身份验证" IsChecked="{Binding Config.Database.UseWindowsAuth}" GroupName="AuthType" Margin="0,0,20,0"/>
                    <RadioButton Content="SQL Server 身份验证" IsChecked="{Binding Config.Database.UseWindowsAuth, Converter={StaticResource InverseBooleanConverter}}" GroupName="AuthType"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Visibility="{Binding Config.Database.UseWindowsAuth, Converter={StaticResource InverseBoolToVisibility}}">
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="用户名:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Config.Database.Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="密码:" VerticalAlignment="Center"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" Margin="0,5" PasswordChanged="PasswordBox_PasswordChanged"/>
                    </Grid>
                </StackPanel>

                <Button Grid.Row="5" Grid.Column="1" Content="测试连接" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,15,0,0" Click="TestConnection_Click"/>
            </Grid>

            <TextBlock x:Name="ConnectionResult" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
