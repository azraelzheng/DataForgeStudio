<Window x:Class="Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:Installer.Pages"
        Title="DataForgeStudio 安装向导"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="30,20">
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" Background="#0078D4" CornerRadius="8" Margin="0,0,15,0">
                    <TextBlock Text="D" Foreground="White" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DataForgeStudio" FontSize="18" FontWeight="Medium" Foreground="#333"/>
                    <TextBlock Text="安装向导" FontSize="12" Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="30,20">
            <Grid>
                <pages:WelcomePage Visibility="{Binding CurrentPageIndex, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=0}"/>
                <pages:InstallPathPage Visibility="{Binding CurrentPageIndex, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=1}"/>
                <pages:DatabaseConfigPage Visibility="{Binding CurrentPageIndex, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=2}"/>
                <pages:PortConfigPage Visibility="{Binding CurrentPageIndex, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=3}"/>
                <pages:ConfirmPage Visibility="{Binding CurrentPageIndex, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=4}"/>
                <pages:ProgressPage Visibility="{Binding CurrentPageIndex, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=5}"/>
                <pages:CompletePage Visibility="{Binding CurrentPageIndex, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=6}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#F0F0F0" Padding="30,15">
            <Grid>
                <Button Content="取消" Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}" HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="上一步" Style="{StaticResource SecondaryButton}"
                            Command="{Binding GoBackCommand}" Margin="0,0,10,0"/>

                    <Button Content="下一步" Command="{Binding GoNextCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentPageIndex}" Value="4">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentPageIndex}" Value="5">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentPageIndex}" Value="6">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="安装" Style="{StaticResource PrimaryButton}"
                            Command="{Binding GoNextCommand}"
                            Visibility="{Binding CurrentPageIndex, Converter={StaticResource InstallButtonVisibilityConverter}}"/>

                    <Button Content="完成" Style="{StaticResource PrimaryButton}"
                            Command="{Binding FinishCommand}"
                            Visibility="{Binding InstallComplete, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
