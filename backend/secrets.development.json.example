{
  "Version": "4.0.0",
  "ReleaseDate": "2026-02-24",
  "Description": "开发环境密钥示例 - 复制为 secrets.production.json 使用",

  "RootUser": {
    "Username": "root",
    "Password": "Admin@123",
    "Note": "系统管理员固定密码，首次安装时自动创建"
  },

  "Keys": {
    "AesKey": "DataForgeStudioV4AESKey32Bytes!!",
    "AesIV": "DataForgeIV16Byt",
    "JwtSecret": "DataForgeStudioV4JWTSecretKey256BitsLongSecure2025ChangeThisInProduction",
    "LicenseAesKey": "DataForgeStudioV4LicenseAES32!!!",
    "LicenseAesIV": "LicenseIV16Bytes"
  },

  "JwtConfig": {
    "Issuer": "DataForgeStudio",
    "Audience": "DataForgeStudio.Client",
    "ExpirationMinutes": 15
  },

  "Instructions": [
    "1. 复制此文件为 secrets.production.json",
    "2. 生成新的随机密钥替换默认值",
    "3. 更新 ProductionKeys.cs 中的常量",
    "4. 备份 secrets.production.json 到安全位置（如密码管理器）",
    "5. secrets.production.json 不应上传到 Git"
  ],

  "KeyLengthRequirements": {
    "AesKey": "精确 32 字符",
    "AesIV": "精确 16 字符",
    "JwtSecret": "至少 64 字符",
    "LicenseAesKey": "精确 32 字符",
    "LicenseAesIV": "精确 16 字符"
  }
}
