{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=localhost;Initial Catalog=DataForgeStudio_V4;Integrated Security=True;TrustServerCertificate=True;",
    "MasterConnection": "Data Source=localhost;Initial Catalog=master;Integrated Security=True;TrustServerCertificate=True;"
  },
  "Security": {
    "Jwt": {
      "Secret": "DataForgeStudioV4JWTSecretKey256BitsLongSecure2025ChangeThisInProduction",
      "Issuer": "DataForgeStudio",
      "Audience": "DataForgeStudio.Client",
      "ExpirationMinutes": 60
    },
    "Encryption": {
      "AesKey": "DataForgeStudioAESKey32BytesLong123456",
      "AesIV": "DataForgeIV16Byte!"
    },
    "License": {
      "AesKey": "${DFS_LICENSE_AES_KEY}",
      "AesIv": "${DFS_LICENSE_AES_IV}"
    },
    "Password": {
      "MinLength": 6,
      "RequireUppercase": false,
      "RequireLowercase": true,
      "RequireDigit": false,
      "RequireSpecialChar": false
    },
    "Login": {
      "MaxFailureCount": 5,
      "LockoutDurationMinutes": 30
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "https://dataforge.example.com"
    ],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
    "AllowedHeaders": ["Authorization", "Content-Type", "X-Requested-With"]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Forwarded-For",
    "HttpStatusCode": 429
  },
  "IpRateLimitPolicies": {
    "IpRules": [
      {
        "Ip": "*",
        "Rules": [
          {
            "Endpoint": "POST:/api/auth/login",
            "Period": "15m",
            "Limit": 5
          },
          {
            "Endpoint": "POST:/api/auth/force-password-change",
            "Period": "15m",
            "Limit": 5
          },
          {
            "Endpoint": "*:/api/reports/test-query",
            "Period": "5m",
            "Limit": 10
          },
          {
            "Endpoint": "*",
            "Period": "1m",
            "Limit": 100
          }
        ]
      }
    ]
  },
  "License": {
    "PublicKeyPath": "keys/public_key.pem",
    "PrivateKeyPath": "keys/private_key.pem",
    "AesKey": "DataForgeStudioV4AESLicenseKey32Bytes!!",
    "AesIv": "DataForgeIV16Byte!"
  },
  "Backup": {
    "Enabled": true,
    "AutoBackupEnabled": false,
    "AutoBackupTime": "02:00",
    "BackupPath": "C:\\Backup\\DataForgeStudio",
    "RetentionDays": 30
  },
  "Upload": {
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".pdf", ".xlsx", ".xls", ".csv"]
  }
}
